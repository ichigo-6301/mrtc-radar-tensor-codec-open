# Copy to flows/local/dc_setup.tcl for either IC_EDA_FULL TSMC90 profile.
# All paths below are local and must never be committed.
set rdtc_stdcell_db REPLACE_WITH_TSMC90_ACI_TYPICAL_1P0V_DB
set rdtc_memory_variant $::env(RDTC_TSMC90_MEMORY_VARIANT)
set rdtc_memory_root "$::env(RDTC_BUILD_ROOT)/sram_tsmc90"

if {$rdtc_memory_variant eq "sram128x128"} {
  set rdtc_sram_db "$rdtc_memory_root/SRAM_DP_ADV_tt_1.0_25.0_syn.db"
  set rdtc_rtl_defines [list RDTC_USE_TSMC90_PREFIX_SRAM_DP_128X128]
  set rdtc_memory_model_files [list \
    "$::env(RDTC_FLOW_ROOT)/flows/memory/tsmc90/sram_dp_adv_wrapper.sv"]
  set rdtc_sram_cell SRAM_DP_ADV
} elseif {$rdtc_memory_variant eq "rf64x128"} {
  set rdtc_sram_db "$rdtc_memory_root/RF_2P_ADV_tt_1.0_25.0_syn.db"
  set rdtc_rtl_defines [list RDTC_USE_TSMC90_PREFIX_RF]
  set rdtc_memory_model_files [list \
    "$::env(RDTC_FLOW_ROOT)/flows/memory/tsmc90/rf_2p_adv_wrapper.sv"]
  set rdtc_sram_cell RF_2P_ADV
} else {
  error "Unsupported RDTC_TSMC90_MEMORY_VARIANT: $rdtc_memory_variant"
}

set search_path [list [file dirname $rdtc_stdcell_db] [file dirname $rdtc_sram_db]]
set target_library [list $rdtc_stdcell_db]
set link_library [concat * $target_library [list $rdtc_sram_db]]
set rdtc_use_sram_macro 1
set rdtc_expected_sram_count 2
