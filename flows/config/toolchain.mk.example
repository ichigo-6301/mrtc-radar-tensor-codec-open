# RDTC_AUDIT_OPENROAD_RUNS := pnr600=/path/to/openroad/pnr600/logs/base pnr500=/path/to/openroad/pnr500/logs/base
# RDTC_AUDIT_DC_NETLIST_COPIES := pnr600=/path/to/pnr600/dc_baseline/top.v pnr500=/path/to/pnr500/dc_baseline/top.v
