# Copy to flows/local/dc_setup.tcl for SKY130 profiles.
# Keep RDTC_SKY130_PDK_ROOT and generated DB paths in ignored local setup.
set stdcell_db "$::env(RDTC_BUILD_ROOT)/sky130_libs/sky130_fd_sc_hd__tt_025C_1v80.db"
set search_path [list [file dirname $stdcell_db]]
set target_library [list $stdcell_db]
set link_library [concat "*" $target_library]

set rdtc_use_sram_macro [expr {$::env(RDTC_MEMORY_MODE) eq "macro"}]
if {$rdtc_use_sram_macro} {
  set sram_db "$::env(RDTC_BUILD_ROOT)/sram_openram/sky130_sram_1kbyte_1rw1r_32x256_8.db"
  lappend search_path [file dirname $sram_db]
  lappend link_library $sram_db
  set rdtc_rtl_defines [list RDTC_USE_SKY130_PREFIX_SRAM]
  set rdtc_sram_cell sky130_sram_1kbyte_1rw1r_32x256_8
  set rdtc_expected_sram_count 8
}
